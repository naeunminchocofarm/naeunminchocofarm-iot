{
  "name": "smartfarm_controller_id_1",
  "crops": [
    {
      "name": "lettuce",
      "sections": [
        {
          "name": "section_1",
          "sensors": [
            {
              "name": "sensor_1",
              "model": "DHT22",
              "target": "air_temperature_humidity",
              "config": {
                "gpio": 27,
                "intervalSeconds": 600
              }
            },
            {
              "name": "sensor_2",
              "model": "ADC",
              "target": "sunshine and soil moisture",
              "config": {
                "enableSunshine": true,
                "sunshineChannel": 0,
                "enableSoilMoisture": true,
                "soilMoistureChannel": 1,
                "intervalSeconds": 600
              }
            }
          ]
        }
      ]
    }
  ]
}
